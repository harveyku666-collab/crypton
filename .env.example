DATABASE_URL=postgresql+asyncpg://bitinfo:bitinfo@localhost:5432/bitinfo
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
DEBUG=false

# Optional but strongly recommended in geo-restricted regions.
# Used for Binance / OKX / Bybit public endpoints.
# Example: PROXY_URL=socks5://127.0.0.1:7890
PROXY_URL=

# Optional: prefer the installed OKX CLI news source when a live OKX profile is configured.
# auto = use official OKX CLI news only when a non-demo/live profile is available, otherwise fall back to public Orbit.
# cli  = always try OKX CLI news first.
# orbit = always use public Orbit news.
OKX_NEWS_SOURCE=auto
# Example: OKX_CLI_PROFILE=live
OKX_CLI_PROFILE=
# Force `okx --live ...` when using the installed CLI.
OKX_CLI_LIVE=false

# AI (optional — enables /api/v1/ai/* predictions)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Exchange API keys (optional — for live trading)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=
